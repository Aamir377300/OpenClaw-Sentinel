openclaw-core/
.openclaw/

# OpenClaw runtime state
openclaw-config/agents/
openclaw-config/logs/
openclaw-config/tasks/
openclaw-config/identity/
openclaw-config/canvas/
openclaw-config/*.sqlite*
openclaw-config/*.jsonl
openclaw-config/*.bak*
openclaw-config/*.last-good

# macOS
.DS_Store

# Editor
.vscode/
.idea/
