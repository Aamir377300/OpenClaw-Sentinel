# SETUP:
#   cp .env.example .env

# LLM Providers Configuration
# Fill in the API key and model for the provider you want to use.
# Then set OPENCLAW_MODEL to the corresponding provider/model ID.

# NVIDIA NIM (https://build.nvidia.com/)
NVIDIA_API_KEY=
NVIDIA_MODEL=z-ai/glm4.7

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ACTIVE MODEL SELECTION
# Format: provider_id/model_id
# Examples:
#   - For NVIDIA:  nvidia_nim/${NVIDIA_MODEL}
#   - For Groq:    groq/${GROQ_MODEL}
#   - For OpenAI:  openai/${OPENAI_MODEL}
OPENCLAW_MODEL=nvidia_nim/${NVIDIA_MODEL}

# OpenClaw Gateway
# Generate with: openssl rand -hex 32
# This token secures the Gateway REST API.
OPENCLAW_GATEWAY_TOKEN=

# Gateway URL (used by the bridge to reach the gateway)
OPENCLAW_GATEWAY_URL=http://gateway:18789


# HMAC Security — Shared Secret

# Used to sign all requests between the bridge and backend and generate with: openssl rand -hex 32
SHARED_SECRET=

# Telegram Bot
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
# Example: TELEGRAM_ALLOWED_IDS=123456789,987654321
TELEGRAM_ALLOWED_IDS=

# -----------------------------------------------------------------------------
# Email Skill (nodemailer + imapflow)
# REQUIRED only if using the email-skill
EMAIL_USER=you@example.com
EMAIL_PASS=your-app-password-here

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# IMAP settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Bridge Server
# OPTIONAL — defaults shown

BRIDGE_PORT=4000
AUDIT_LOG_PATH=/home/node/app/audit_log.json

# Workspace Skill
# OPTIONAL — defaults to /workspace inside Docker
WORKSPACE_DIR=/home/node/app/workspace
